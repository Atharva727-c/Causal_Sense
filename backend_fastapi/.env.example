# ── CausalSense FastAPI Backend ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Required: Anthropic API key (leave empty to run in mock/demo mode)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override Claude model
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: Server settings
# HOST=0.0.0.0
# PORT=8001
# DEBUG=false
# ENVIRONMENT=development

# Optional: CORS — add your frontend origin if it differs from localhost:5173
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── EPAM DIAL (Azure OpenAI proxy) — powers the EDA pipeline ──────────────────
# Required for the EDA pipeline. Leave DIAL_API_KEY empty to run it in mock mode.
DIAL_API_KEY=dial-...
DIAL_ENDPOINT=https://ai-proxy.lab.epam.com
DIAL_API_VERSION=2024-02-01
DIAL_CHAT_DEPLOYMENT=gpt-5.5-2026-04-24-reasoning
# Embeddings deployment — edit to whatever your DIAL tenant exposes:
DIAL_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large
# Reasoning models reject the `temperature` param — set false for non-reasoning models:
# DIAL_IS_REASONING_MODEL=true
# DIAL_MAX_COMPLETION_TOKENS=8192

# ── EDA pipeline tuning ───────────────────────────────────────────────────────
# EDA_SEND_PLOT_IMAGES=true       # send plot PNGs to the vision model (set false for text-only)
# EDA_VECTOR_TOP_K=5
# EDA_CHUNK_SIZE=1200
# EDA_CHUNK_OVERLAP=150
# EDA_SAMPLE_ROWS=100000
# EDA_REACT_MAX_ITERATIONS=8
