import json
import numpy as np
import pandas as pd
import scipy.stats as stats

df = pd.read_csv(r"{{ dataset_path }}")
col_a = {{ col_a|tojson }}
col_b = {{ col_b|tojson }}

clean = df[[col_a, col_b]].dropna()
contingency = pd.crosstab(clean[col_a], clean[col_b])

if contingency.shape[0] < 2 or contingency.shape[1] < 2:
    print(json.dumps({"test": "chi_square", "error": "insufficient_categories"}))
else:
    chi2, p_value, dof, expected = stats.chi2_contingency(contingency)
    n = contingency.values.sum()
    min_dim = min(contingency.shape) - 1
    cramers_v = float(np.sqrt((chi2 / n) / min_dim)) if min_dim > 0 else 0.0
    print(json.dumps({
        "test": "chi_square",
        "statistic": float(chi2),
        "p_value": float(p_value),
        "effect_size": cramers_v,
        "effect_name": "cramers_v",
        "n": int(n),
        "columns": {"col_a": col_a, "col_b": col_b},
    }))
