import json
import pandas as pd
import scipy.stats as stats

df = pd.read_csv(r"{{ dataset_path }}")
numeric_col = {{ numeric_col|tojson }}
categorical_col = {{ categorical_col|tojson }}

def _trim_percentile(df_in, col, lower_q=0.025, upper_q=0.975):
    lo, hi = df_in[col].quantile(lower_q), df_in[col].quantile(upper_q)
    mask = (df_in[col] >= lo) & (df_in[col] <= hi)
    return df_in[mask], int((~mask).sum())

pre_trim = df[[numeric_col, categorical_col]].dropna()
clean, outliers_removed = _trim_percentile(pre_trim, numeric_col)
groups = [g[numeric_col].values for _, g in clean.groupby(categorical_col) if len(g) >= {{ min_group_size }}]
group_count = len(groups)

if group_count < 2:
    print(json.dumps({"test": "group_diff", "error": "insufficient_groups"}))
else:
    if group_count > 2:
        stat, p_value = stats.f_oneway(*groups)
        test_name = "anova"
        grand_mean = clean[numeric_col].mean()
        ss_between = sum(len(g) * (g.mean() - grand_mean) ** 2 for g in groups)
        ss_total = ((clean[numeric_col] - grand_mean) ** 2).sum()
        effect_size = float(ss_between / ss_total) if ss_total else 0.0
        effect_name = "eta_squared"
    else:
        stat, p_value = stats.ttest_ind(*groups, equal_var=False)
        test_name = "welch_t"
        pooled_std = (groups[0].std(ddof=1) + groups[1].std(ddof=1)) / 2
        effect_size = float(abs(groups[0].mean() - groups[1].mean()) / pooled_std) if pooled_std else 0.0
        effect_name = "cohens_d"

    group_means = clean.groupby(categorical_col)[numeric_col].mean().to_dict()
    group_p75 = clean.groupby(categorical_col)[numeric_col].quantile(0.75).to_dict()
    group_p90 = clean.groupby(categorical_col)[numeric_col].quantile(0.90).to_dict()

    print(json.dumps({
        "test": test_name,
        "statistic": float(stat),
        "p_value": float(p_value),
        "effect_size": effect_size,
        "effect_name": effect_name,
        "group_means": {str(k): float(v) for k, v in group_means.items()},
        "group_p75": {str(k): float(v) for k, v in group_p75.items()},
        "group_p90": {str(k): float(v) for k, v in group_p90.items()},
        "outliers_removed": {numeric_col: outliers_removed},
        "columns": {"numeric_col": numeric_col, "categorical_col": categorical_col},
    }))
