import json
import pandas as pd

df = pd.read_csv(r"{{ dataset_path }}")
group_col = {{ group_col|tojson }}
breakdown_col = {{ breakdown_col|tojson }}
numeric_cols = {{ numeric_cols|tojson }}

def _trim_percentile(df_in, col, lower_q=0.025, upper_q=0.975):
    lo, hi = df_in[col].quantile(lower_q), df_in[col].quantile(upper_q)
    mask = (df_in[col] >= lo) & (df_in[col] <= hi)
    return df_in[mask], int((~mask).sum())

clean = df[[group_col, breakdown_col] + numeric_cols].dropna(subset=[group_col, breakdown_col])

if len(clean) < {{ min_group_size }} or clean[group_col].nunique() < 2 or clean[breakdown_col].nunique() < 2:
    print(json.dumps({"test": "cross_top_n", "error": "insufficient_rows"}))
else:
    group_order = (
        clean.groupby(group_col)[numeric_cols[0]].count().sort_values(ascending=False).index
    )
    by_numeric = {}
    outliers_removed = {}
    for numeric_col in numeric_cols:
        col_clean = clean.dropna(subset=[numeric_col])
        col_trimmed, removed = _trim_percentile(col_clean, numeric_col)
        outliers_removed[numeric_col] = removed
        agg = col_trimmed.groupby([group_col, breakdown_col])[numeric_col].agg(["sum", "count"]).reset_index()
        groups = []
        for g in group_order:
            sub = agg[agg[group_col] == g].sort_values("sum", ascending=False).head(3)
            if sub.empty:
                continue
            groups.append({
                "group": str(g),
                "top": [
                    {"breakdown": str(row[breakdown_col]), "value": float(row["sum"]), "count": int(row["count"])}
                    for _, row in sub.iterrows()
                ],
            })
        by_numeric[numeric_col] = groups

    print(json.dumps({
        "test": "cross_top_n",
        "n": int(len(clean)),
        "columns": {"group_col": group_col, "breakdown_col": breakdown_col},
        "by_numeric": by_numeric,
        "outliers_removed": outliers_removed,
    }))
