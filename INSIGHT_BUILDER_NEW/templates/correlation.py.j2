import json
import pandas as pd
import scipy.stats as stats

df = pd.read_csv(r"{{ dataset_path }}")
col_a = {{ col_a|tojson }}
col_b = {{ col_b|tojson }}

def _trim_percentile(df_in, cols, lower_q=0.025, upper_q=0.975):
    mask = pd.Series(True, index=df_in.index)
    removed = {}
    for c in cols:
        lo, hi = df_in[c].quantile(lower_q), df_in[c].quantile(upper_q)
        col_mask = (df_in[c] >= lo) & (df_in[c] <= hi)
        removed[c] = int((~col_mask).sum())
        mask &= col_mask
    return df_in[mask], removed

pre_trim = df[[col_a, col_b]].dropna()
clean, outliers_removed = _trim_percentile(pre_trim, [col_a, col_b])

if len(clean) < 5:
    print(json.dumps({"test": "correlation", "error": "insufficient_rows"}))
else:
    r, p_value = stats.pearsonr(clean[col_a], clean[col_b])
    print(json.dumps({
        "test": "pearson",
        "statistic": float(r),
        "p_value": float(p_value),
        "effect_size": float(abs(r)),
        "effect_name": "abs_r",
        "n": int(len(clean)),
        "outliers_removed": outliers_removed,
        "columns": {"col_a": col_a, "col_b": col_b},
    }))
