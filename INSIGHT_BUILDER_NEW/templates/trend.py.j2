import json
import pandas as pd
import scipy.stats as stats

df = pd.read_csv(r"{{ dataset_path }}", parse_dates=["{{ datetime_col }}"])
numeric_col = {{ numeric_col|tojson }}
datetime_col = {{ datetime_col|tojson }}

def _trim_percentile(df_in, col, lower_q=0.025, upper_q=0.975):
    lo, hi = df_in[col].quantile(lower_q), df_in[col].quantile(upper_q)
    mask = (df_in[col] >= lo) & (df_in[col] <= hi)
    return df_in[mask], int((~mask).sum())

pre_trim = df[[numeric_col, datetime_col]].dropna()
trimmed, outliers_removed = _trim_percentile(pre_trim, numeric_col)
clean = trimmed.sort_values(datetime_col)

if len(clean) < 10:
    print(json.dumps({"test": "trend", "error": "insufficient_rows"}))
else:
    time_ordinal = clean[datetime_col].rank(method="first")
    rho, p_value = stats.spearmanr(time_ordinal, clean[numeric_col])

    midpoint = clean[datetime_col].median()
    first_half = clean[clean[datetime_col] <= midpoint][numeric_col]
    second_half = clean[clean[datetime_col] > midpoint][numeric_col]

    print(json.dumps({
        "test": "spearman_trend",
        "statistic": float(rho),
        "p_value": float(p_value),
        "effect_size": float(abs(rho)),
        "effect_name": "abs_rho",
        "direction": "increasing" if rho > 0 else "decreasing",
        "n": int(len(clean)),
        "first_half_mean": float(first_half.mean()) if len(first_half) else None,
        "second_half_mean": float(second_half.mean()) if len(second_half) else None,
        "p75": float(clean[numeric_col].quantile(0.75)),
        "p90": float(clean[numeric_col].quantile(0.90)),
        "outliers_removed": {numeric_col: outliers_removed},
        "columns": {"numeric_col": numeric_col, "datetime_col": datetime_col},
    }))
